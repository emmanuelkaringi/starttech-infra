{
  "alarms": [
    {
      "name": "High CPU Alarm",
      "description": "Triggers when CPU exceeds 80% for 10 minutes",
      "metric": "CPUUtilization",
      "namespace": "AWS/EC2",
      "threshold": 80,
      "evaluation_periods": 2,
      "period": 300
    },
    {
      "name": "Healthy Hosts Alarm",
      "description": "Triggers when healthy host count drops below 1",
      "metric": "HealthyHostCount",
      "namespace": "AWS/ApplicationELB",
      "threshold": 1,
      "evaluation_periods": 2,
      "period": 300
    },
    {
      "name": "Redis CPU Alarm",
      "description": "Triggers when Redis CPU exceeds 80%",
      "metric": "CPUUtilization",
      "namespace": "AWS/ElastiCache",
      "threshold": 80,
      "evaluation_periods": 2,
      "period": 300
    }
  ]
}
